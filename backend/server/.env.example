# 📌 COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# DO NOT COMMIT .env FILE TO GIT - IT'S IN .gitignore

# ✅ MongoDB Atlas Connection String
# Get this from: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster-name.mongodb.net/database_name?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@your-cluster.mongodb.net/vienstereoptic_crm?retryWrites=true&w=majority

# ✅ Email Configuration (Gmail with App Password)
# Steps to get App Password:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification
# 3. Go to "App passwords" (or generate here: https://myaccount.google.com/apppasswords)
# 4. Select "Mail" and "Windows Computer" (or your device)
# 5. Copy the 16-character password generated
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password

# Company email (where admin receives notifications)
COMPANY_EMAIL=your-email@gmail.com

# ✅ Django Settings
DEBUG=True
SECRET_KEY=django-insecure-ot*sj(tjm3+-z2$c_&x1pgjw()$d_4nvdia2a5eoi8j6+j(k3$
